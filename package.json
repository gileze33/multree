{
    "name": "multree-cli",
    "version": "0.1.1",
    "description": "Multi-repo git worktree group orchestrator: spin up linked worktrees across N repos, run per-repo hooks, prime heavy artifacts via APFS reflinks, and wire consumer env files to values exposed by producer repos.",
    "type": "module",
    "license": "MIT",
    "author": "Giles Boon-Williams",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/gileze33/multree.git"
    },
    "bugs": {
        "url": "https://github.com/gileze33/multree/issues"
    },
    "homepage": "https://github.com/gileze33/multree#readme",
    "keywords": [
        "git",
        "worktree",
        "monorepo",
        "polyrepo",
        "cli",
        "dev-tools",
        "reflink",
        "apfs"
    ],
    "bin": {
        "multree": "./dist/cli.mjs"
    },
    "files": [
        "dist",
        "multree.config.example.yaml",
        "CHANGELOG.md",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "typecheck": "tsc --noEmit",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "dev": "tsx src/cli.ts",
        "build": "tsdown",
        "test": "tsx --test tests/unit/*.test.ts tests/integration/*.test.ts",
        "test:unit": "tsx --test tests/unit/*.test.ts",
        "test:integration": "tsx --test tests/integration/*.test.ts",
        "changelog": "auto-changelog",
        "version": "auto-changelog -p && git add CHANGELOG.md",
        "prepublishOnly": "pnpm typecheck && pnpm lint && pnpm test && pnpm build"
    },
    "auto-changelog": {
        "commitLimit": false,
        "hideCredit": true,
        "template": "keepachangelog",
        "unreleased": true
    },
    "dependencies": {
        "yaml": "^2.6.0"
    },
    "devDependencies": {
        "@types/node": "^25.8.0",
        "@typescript-eslint/parser": "^8.55.0",
        "auto-changelog": "^2.5.1",
        "eslint": "^10.3.0",
        "tsdown": "^0.22.0",
        "tsx": "^4.19.2",
        "typescript": "^5.6.3"
    },
    "engines": {
        "node": ">=20.6"
    },
    "packageManager": "pnpm@11.0.8"
}
