{
    "name": "multree",
    "version": "0.1.0",
    "description": "Multi-repo git worktree group orchestrator",
    "type": "module",
    "bin": {
        "multree": "./bin/multree"
    },
    "scripts": {
        "typecheck": "tsc --noEmit",
        "dev": "tsx src/cli.ts",
        "test": "tsx --test tests/unit/*.test.ts tests/integration/*.test.ts",
        "test:unit": "tsx --test tests/unit/*.test.ts",
        "test:integration": "tsx --test tests/integration/*.test.ts"
    },
    "dependencies": {
        "tsx": "^4.19.2",
        "yaml": "^2.6.0"
    },
    "devDependencies": {
        "@types/node": "^22.10.0",
        "typescript": "^5.6.3"
    },
    "engines": {
        "node": ">=20.6"
    }
}
